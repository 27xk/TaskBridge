<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules xmlns:android="http://schemas.android.com/apk/res/android">
    <cloud-backup>
        <exclude domain="sharedpref" path="taskbridge_secure_tokens.xml" />
        <exclude domain="sharedpref" path="taskbridge_device.xml" />
        <exclude domain="sharedpref" path="taskbridge_sync.preferences_pb" />
        <exclude domain="database" path="taskbridge.db" />
        <exclude domain="database" path="taskbridge.db-shm" />
        <exclude domain="database" path="taskbridge.db-wal" />
        <exclude domain="file" path="exports" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="taskbridge_secure_tokens.xml" />
        <exclude domain="sharedpref" path="taskbridge_device.xml" />
        <exclude domain="sharedpref" path="taskbridge_sync.preferences_pb" />
        <exclude domain="database" path="taskbridge.db" />
        <exclude domain="database" path="taskbridge.db-shm" />
        <exclude domain="database" path="taskbridge.db-wal" />
        <exclude domain="file" path="exports" />
    </device-transfer>
</data-extraction-rules>
