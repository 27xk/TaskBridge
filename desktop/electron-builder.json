{
  "appId": "com.taskbridge.desktop",
  "productName": "TaskBridge",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**/*",
    "build/icon.ico",
    "package.json",
    "!**/*.map",
    "!**/*.tsbuildinfo",
    "!**/*.log",
    "!**/node_modules/**/*.d.ts",
    "!**/node_modules/**/*.ts",
    "!**/node_modules/**/*.tsx",
    "!**/node_modules/**/*.c",
    "!**/node_modules/**/*.cc",
    "!**/node_modules/**/*.h",
    "!**/node_modules/.bin/**",
    "!**/node_modules/**/.editorconfig",
    "!**/node_modules/**/.eslintrc*",
    "!**/node_modules/**/.npmignore",
    "!**/node_modules/**/.prettierrc*",
    "!**/node_modules/**/.travis.yml",
    "!**/README.md",
    "!**/CHANGELOG*",
    "!**/HISTORY*",
    "!**/node_modules/**/*.md",
    "!**/node_modules/**/docs/**",
    "!**/node_modules/**/doc/**",
    "!**/node_modules/**/example/**",
    "!**/node_modules/**/examples/**",
    "!**/node_modules/**/benchmark/**",
    "!**/node_modules/**/benchmarks/**",
    "!**/node_modules/**/src/**",
    "!**/node_modules/**/test/**",
    "!**/node_modules/**/tests/**",
    "!**/node_modules/**/coverage/**",
    "!**/node_modules/**/.github/**",
    "!**/node_modules/**/.vscode/**",
    "!**/node_modules/better-sqlite3/binding.gyp",
    "!**/node_modules/better-sqlite3/deps/**",
    "!**/node_modules/better-sqlite3/src/**",
    "!**/node_modules/better-sqlite3/build/Release/obj.target/**",
    "!**/node_modules/better-sqlite3/build/Release/test_extension.node",
    "!**/node_modules/better-sqlite3/build/Release/*.exp",
    "!**/node_modules/better-sqlite3/build/Release/*.iobj",
    "!**/node_modules/better-sqlite3/build/Release/*.ipdb",
    "!**/node_modules/better-sqlite3/build/Release/*.lib",
    "!**/node_modules/better-sqlite3/build/Release/*.pdb",
    "!**/node_modules/better-sqlite3/build/Release/*.obj",
    "!**/node_modules/better-sqlite3/build/*.mk",
    "!**/node_modules/better-sqlite3/build/*.Makefile",
    "!**/node_modules/better-sqlite3/build/config.gypi",
    "!**/node_modules/prebuild-install/**",
    "!**/node_modules/base64-js/**",
    "!**/node_modules/bl/**",
    "!**/node_modules/buffer/**",
    "!**/node_modules/deep-extend/**",
    "!**/node_modules/end-of-stream/**",
    "!**/node_modules/expand-template/**",
    "!**/node_modules/fs-constants/**",
    "!**/node_modules/ieee754/**",
    "!**/node_modules/inherits/**",
    "!**/node_modules/ini/**",
    "!**/node_modules/minimist/**",
    "!**/node_modules/once/**",
    "!**/node_modules/pump/**",
    "!**/node_modules/rc/**",
    "!**/node_modules/readable-stream/**",
    "!**/node_modules/safe-buffer/**",
    "!**/node_modules/string_decoder/**",
    "!**/node_modules/strip-json-comments/**",
    "!**/node_modules/tunnel-agent/**",
    "!**/node_modules/util-deprecate/**",
    "!**/node_modules/wrappy/**",
    "!**/node_modules/node-abi/**",
    "!**/node_modules/napi-build-utils/**",
    "!**/node_modules/detect-libc/**",
    "!**/node_modules/decompress-response/**",
    "!**/node_modules/github-from-package/**",
    "!**/node_modules/mkdirp-classic/**",
    "!**/node_modules/simple-concat/**",
    "!**/node_modules/simple-get/**",
    "!**/node_modules/tar-fs/**",
    "!**/node_modules/tar-stream/**",
    "!**/.vite/**",
    "!**/.cache/**",
    "!**/test/**",
    "!**/tests/**"
  ],
  "asar": true,
  "asarUnpack": [
    "**/better_sqlite3.node"
  ],
  "compression": "maximum",
  "electronLanguages": [
    "zh-CN",
    "en-US"
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      "nsis"
    ],
    "artifactName": "TaskBridge-${version}-Setup.${ext}"
  },
  "nsis": {
    "include": "build/installer.nsh",
    "differentialPackage": false,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
