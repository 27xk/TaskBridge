{
  "name": "taskbridge-desktop",
  "version": "0.1.3",
  "private": true,
  "description": "TaskBridge Windows desktop app",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node ./scripts/rebuild-native.mjs",
    "predev": "node ./scripts/ensure-native.mjs",
    "predist": "node ./scripts/ensure-native.mjs",
    "rebuild:native": "node ./scripts/rebuild-native.mjs",
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "dist": "npm run build && electron-builder --config electron-builder.json",
    "check:task-order": "node ./scripts/check-task-order.mjs",
    "check:quick-add-parser": "node ./scripts/check-quick-add-parser.mjs",
    "check:sync-push": "node ./scripts/check-sync-push-handling.mjs",
    "clean": "node ./scripts/clean.mjs",
    "clean:all": "node ./scripts/clean.mjs --all"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "electron-store": "^10.0.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@swc/core": "^1.11.24",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.9.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.1.10"
  }
}
