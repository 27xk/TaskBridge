{
  "name": "taskbridge-desktop",
  "version": "0.1.7",
  "private": true,
  "description": "TaskBridge Windows desktop app",
  "type": "module",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/27xk/TaskBridge.git",
    "directory": "desktop"
  },
  "engines": {
    "node": ">=22.12.0 <24",
    "npm": ">=10 <12"
  },
  "scripts": {
    "postinstall": "node ./scripts/rebuild-native.mjs",
    "predev": "node ./scripts/ensure-native.mjs",
    "predist": "node ./scripts/ensure-native.mjs",
    "rebuild:native": "node ./scripts/rebuild-native.mjs",
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "test:unit": "node --test \"tests/**/*.test.mjs\"",
    "typecheck": "vue-tsc --noEmit",
    "dist": "npm run build && electron-builder --config electron-builder.json --publish never",
    "check:task-order": "node ./scripts/check-task-order.mjs",
    "check:lockfile-registry": "node ./scripts/check-lockfile-registry.mjs",
    "check:desktop-endpoint-config": "node ./scripts/check-desktop-endpoint-config.mjs",
    "check:package-size-config": "node ./scripts/check-package-size-config.mjs",
    "check:security-config": "node ./scripts/check-security-config.mjs",
    "check:auth-session-config": "node ./scripts/check-auth-session-config.mjs",
    "check:backend-observability": "node ./scripts/check-backend-observability-config.mjs",
    "check:quick-add-parser": "node ./scripts/check-quick-add-parser.mjs",
    "check:sync-push": "node ./scripts/check-sync-push-handling.mjs",
    "check:sync-diagnostics": "node ./scripts/check-sync-diagnostics.mjs",
    "check:sync-recovery-center": "node ./scripts/check-sync-recovery-center-config.mjs",
    "check:desktop-backup": "node ./scripts/check-desktop-backup-config.mjs",
    "check:desktop-theme": "node ./scripts/check-desktop-theme-config.mjs",
    "check:desktop-efficiency": "node ./scripts/check-desktop-efficiency-config.mjs",
    "check:desktop-docs": "node ./scripts/check-desktop-docs.mjs",
    "check:local-bootstrap": "node ./scripts/check-local-bootstrap-config.mjs",
    "check:release-readiness": "node ./scripts/check-release-readiness-config.mjs",
    "check:release-artifacts": "node ./scripts/check-release-artifacts-config.mjs",
    "check:production-hardening": "node ./scripts/check-production-hardening-config.mjs",
    "check:desktop-task-list-completeness": "node ./scripts/check-desktop-task-list-completeness.mjs",
    "check:android-localization": "node ./scripts/check-android-localization-config.mjs",
    "check:android-task-delete-confirmation": "node ./scripts/check-android-task-delete-confirmation-config.mjs",
    "check:refresh-singleflight": "node ./scripts/check-refresh-singleflight-config.mjs",
    "check:registration-governance": "node ./scripts/check-registration-governance-config.mjs",
    "check:sync-retry-preservation": "node ./scripts/check-sync-retry-preservation-config.mjs",
    "check:android-list-realtime": "node ./scripts/check-android-list-realtime-config.mjs",
    "check:release-endpoint-defaults": "node ./scripts/check-release-endpoint-defaults-config.mjs",
    "check:android-sync-status-message": "node ./scripts/check-android-sync-status-message-config.mjs",
    "check:android-sync-recovery": "node ./scripts/check-android-sync-recovery-config.mjs",
    "check:ci-workflows": "node ./scripts/check-ci-workflow-config.mjs",
    "check:contract-drift": "node ./scripts/check-contract-drift.mjs",
    "check:source-tests-visible": "node ./scripts/check-source-tests-visible-config.mjs",
    "check:supply-chain": "node ./scripts/check-supply-chain-config.mjs",
    "check:desktop-auto-update": "node ./scripts/check-desktop-auto-update-config.mjs",
    "check:android-data-extraction": "node ./scripts/check-android-data-extraction-config.mjs",
    "check:security-governance": "node ./scripts/check-security-governance-config.mjs",
    "check:ux-priority-polish": "node ./scripts/check-ux-priority-polish.mjs",
    "check:user-experience": "node ./scripts/check-user-experience-optimizations.mjs",
    "clean": "node ./scripts/clean.mjs",
    "clean:dry-run": "node ./scripts/clean.mjs --dry-run",
    "clean:all": "node ./scripts/clean.mjs --all"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.9.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
