{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": [
    "electron/**/*.ts",
    "shared/**/*.ts",
    "src/**/*.ts",
    "src/**/*.vue",
    "src/env.d.ts",
    "electron.vite.config.ts",
    "vite.config.ts"
  ]
}
