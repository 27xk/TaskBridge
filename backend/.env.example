# TaskBridge backend environment example for external MySQL / Redis.
# Copy this file to backend/.env and update the values before starting.
#
# Windows PowerShell:
#   Copy-Item .env.example .env
#
# Notes:
# - The backend runtime reads DATABASE_URL, REDIS_URL and JWT_SECRET.
# - MYSQL_ROOT_PASSWORD is only needed when Docker Compose initializes MySQL.
# - If you use an external MySQL server, do not set MYSQL_ROOT_PASSWORD here.

# Display name used by OpenAPI and logs.
APP_NAME=TaskBridge API

# Display version.
APP_VERSION=0.1.6

# Runtime environment: development, staging or production.
ENVIRONMENT=development

# MySQL connection URL.
# Format:
#   mysql+pymysql://user:password@host:port/database
#
# External MySQL example:
#   mysql+pymysql://taskbridge:your-password@192.168.1.20:3306/taskbridge
#
# Local MySQL example:
#   mysql+pymysql://taskbridge:your-password@127.0.0.1:3306/taskbridge
#
# The database and user must already exist.
# Run "alembic upgrade head" to create or upgrade tables.
DATABASE_URL=mysql+pymysql://taskbridge:change-this-password@127.0.0.1:3306/taskbridge

# SQLAlchemy connection pool size. Personal or low-memory deployments can keep this small.
DATABASE_POOL_SIZE=3

# Extra temporary connections allowed during bursts.
DATABASE_MAX_OVERFLOW=2

# Recycle idle database connections periodically to avoid stale MySQL connections.
DATABASE_POOL_RECYCLE_SECONDS=1800

# Redis connection URL.
# External Redis example:
#   redis://192.168.1.30:6379/0
#
# Local Redis example:
#   redis://127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# JWT signing secret. Must be changed before production.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-this-with-a-random-secret-at-least-32-bytes

# JWT algorithm. Keep HS256 unless you know why to change it.
JWT_ALGORITHM=HS256

# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days.
REFRESH_TOKEN_EXPIRE_DAYS=30

# WebSocket ticket lifetime in seconds.
WEBSOCKET_TICKET_EXPIRE_SECONDS=60
