# TaskBridge backend environment example for Docker Compose.
# Copy this file to backend/.env when using backend/docker-compose.yml.
#
# Windows PowerShell:
#   Copy-Item .env.docker.example .env
#
# Notes:
# - MYSQL_ROOT_PASSWORD is only used to initialize the bundled MySQL container.
# - If you use an external MySQL server, copy .env.example instead.

APP_NAME=TaskBridge API
APP_VERSION=0.1.6
ENVIRONMENT=development

# Docker Compose service names are mysql and redis.
DATABASE_URL=mysql+pymysql://taskbridge:change-this-password@mysql:3306/taskbridge
REDIS_URL=redis://redis:6379/0

# MySQL container initialization variables.
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=taskbridge
MYSQL_USER=taskbridge
MYSQL_PASSWORD=change-this-password

JWT_SECRET=replace-this-with-a-random-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
WEBSOCKET_TICKET_EXPIRE_SECONDS=60
REGISTRATION_ENABLED=true
METRICS_ENABLED=true
METRICS_TOKEN=
TRUSTED_PROXY_IPS=
WEB_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
