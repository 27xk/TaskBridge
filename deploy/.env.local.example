# TaskBridge local trial environment example.
# Copy this file to deploy/.env when you only want to try TaskBridge on this computer.
#
# Windows PowerShell:
#   Copy-Item .env.local.example .env

TASKBRIDGE_BACKEND_IMAGE=ghcr.io/27xk/taskbridge:latest
TASKBRIDGE_API_BIND=8000
TASKBRIDGE_WEB_BIND=8080

MYSQL_ROOT_PASSWORD=taskbridge-local-root-password
MYSQL_DATABASE=taskbridge
MYSQL_USER=taskbridge
MYSQL_PASSWORD=taskbridge-local-password

APP_NAME=TaskBridge API
APP_VERSION=0.1.8
ENVIRONMENT=development

DATABASE_URL=mysql+pymysql://taskbridge:taskbridge-local-password@mysql:3306/taskbridge
REDIS_URL=redis://redis:6379/0

JWT_SECRET=taskbridge-local-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
WEBSOCKET_TICKET_EXPIRE_SECONDS=60
REGISTRATION_ENABLED=true

METRICS_ENABLED=false
METRICS_TOKEN=
TRUSTED_PROXY_IPS=172.30.27.10

# Local trial uses development mode, so wildcard CORS lets phones and other
# LAN devices open the static Web/PWA from their own hostnames during testing.
WEB_CORS_ORIGINS=*
