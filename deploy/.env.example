# TaskBridge deployment environment example.
# Copy this file to deploy/.env before running docker compose.
#
# Windows PowerShell:
#   Copy-Item .env.example .env

# Backend image.
# Default release image is published to GHCR.
# Docker Hub alternative: 27xk/taskbridge:latest
TASKBRIDGE_BACKEND_IMAGE=ghcr.io/27xk/taskbridge:latest

# MySQL root password. Change this before using shared or production hosts.
MYSQL_ROOT_PASSWORD=change-this-root-password

# MySQL database name.
MYSQL_DATABASE=taskbridge

# MySQL application user.
MYSQL_USER=taskbridge

# MySQL application user password.
# The backend DATABASE_URL password must match this value when using this MySQL.
MYSQL_PASSWORD=change-this-password

# Backend runtime.
APP_NAME=TaskBridge API
APP_VERSION=0.1.0
ENVIRONMENT=production

# Docker Compose service names are mysql and redis.
DATABASE_URL=mysql+pymysql://taskbridge:change-this-password@mysql:3306/taskbridge
REDIS_URL=redis://redis:6379/0

# Change this before production deployment.
JWT_SECRET=replace-this-with-a-random-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
WEBSOCKET_TICKET_EXPIRE_SECONDS=60
